# NexusTrack Environment Configuration
# Copy this to .env and fill in production values

# Security — CHANGE THIS IN PRODUCTION (use: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=nexustrack-dev-secret-change-in-production-now

# Server
PORT=5000
FLASK_ENV=development
# FLASK_ENV=production  # use this in prod

# Database
# DB_PATH=./nexustrack.db  # default, relative to backend/

# CORS — set to your frontend domain in production
# ALLOWED_ORIGIN=https://yourdomain.com

# Email (optional — for notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=no-reply@nexustrack.com
